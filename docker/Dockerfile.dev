# Development Dockerfile with hot-reload
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[dev]"

# Copy source code (volumes override in docker-compose)
COPY src/ src/
COPY static/ static/
COPY config/ config/
COPY migrations/ migrations/
COPY alembic.ini .
COPY tests/ tests/

ENV PYTHONUNBUFFERED=1
ENV ARGUS_DEV_MODE=true
ENV ARGUS_CONFIG_PATH=/app/config/argus.yaml

EXPOSE 8000

CMD ["uvicorn", "argus.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/src"]
